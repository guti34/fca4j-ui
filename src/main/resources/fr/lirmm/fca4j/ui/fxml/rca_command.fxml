<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToWidth="true"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="fr.lirmm.fca4j.ui.controller.RcaCommandController">
<VBox spacing="8" style="-fx-padding: 10;">

    <!-- Entrée -->
    <TitledPane fx:id="inputPane" collapsible="false">
        <VBox spacing="8" style="-fx-padding: 8;">
            <HBox spacing="6">
                <TextField fx:id="familyFileField" HBox.hgrow="ALWAYS"
                           promptText="%rca.family.prompt"/>
                <Button text="%button.browse" onAction="#onBrowseFamily"/>
                <Button fx:id="editFamilyButton" onAction="#onEditFamily"/>
            </HBox>
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label text="%rca.family.format"/>
                <ComboBox fx:id="familyFormatCombo" prefWidth="110"/>
            </HBox>
        </VBox>
    </TitledPane>

    <!-- Sortie -->
    <TitledPane fx:id="outputPane" collapsible="false">
        <VBox spacing="6" style="-fx-padding: 8;">
            <HBox spacing="6">
                <TextField fx:id="outputFolderField" HBox.hgrow="ALWAYS"
                           promptText="%rca.output.folder.prompt"/>
                <Button text="%button.browse" onAction="#onBrowseOutputFolder"/>
            </HBox>
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label text="%rca.limit.steps"/>
                <Spinner fx:id="limitStepsSpinner" prefWidth="75"/>
                <Label text="%rca.limit.steps.hint"
                       style="-fx-text-fill: gray; -fx-font-size: 11px;"/>
            </HBox>
            <CheckBox fx:id="storeExtendedFamily"   text="%rca.store.extended"/>
            <CheckBox fx:id="storeExtendedEachStep" text="%rca.store.extended.steps"/>
            <CheckBox fx:id="buildXml"              text="%rca.build.xml"/>
            <CheckBox fx:id="addFullExtents"        text="%rca.full.extents"/>
            <CheckBox fx:id="addFullIntents"        text="%rca.full.intents"/>
			<CheckBox fx:id="buildJson"       text="%rca.build.json"/>            
        </VBox>
    </TitledPane>

    <!-- Algorithme -->
    <TitledPane fx:id="algoPane" collapsible="false">
        <VBox spacing="6" style="-fx-padding: 8;">
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label text="%label.algorithm"/>
                <ComboBox fx:id="algoCombo" prefWidth="140"/>
            </HBox>
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label fx:id="icebergLabel" text="%label.iceberg.percent"/>
                <Spinner fx:id="icebergSpinner" prefWidth="75"/>
            </HBox>
        </VBox>
    </TitledPane>

    <!-- Renommage -->
    <TitledPane fx:id="namingPane" collapsible="true" expanded="false">
        <VBox spacing="6" style="-fx-padding: 8;">
            <Label text="%rca.naming.hint"
                   style="-fx-text-fill: gray; -fx-font-size: 11px;" wrapText="true"/>
            <CheckBox fx:id="renameRA"   text="%rca.rename.ra"/>
            <CheckBox fx:id="renameRAI"  text="%rca.rename.rai"/>
            <CheckBox fx:id="renameRI"   text="%rca.rename.ri"/>
            <CheckBox fx:id="nativeOnly" text="%rca.native.only"/>
            <Separator/>
            <CheckBox fx:id="cleanOption" text="%rca.clean"/>
        </VBox>
    </TitledPane>

    <!-- GraphViz -->
    <TitledPane fx:id="graphvizPane" collapsible="true" expanded="false">
        <VBox spacing="6" style="-fx-padding: 8;">
            <CheckBox fx:id="buildDot" text="%rca.build.dot"/>
            <HBox spacing="8" alignment="CENTER_LEFT" style="-fx-padding: 0 0 0 16;">
                <Label fx:id="displayModeLabel" text="%label.display.mode"/>
                <ComboBox fx:id="displayModeCombo" prefWidth="120"/>
            </HBox>
            <CheckBox fx:id="stability" text="%checkbox.stability"
                      style="-fx-padding: 0 0 0 16;"/>
        </VBox>
    </TitledPane>

    <!-- Datalog -->
    <TitledPane fx:id="datalogPane" collapsible="true" expanded="false">
        <VBox spacing="6" style="-fx-padding: 8;">
            <Label text="%rca.datalog.hint"
                   style="-fx-text-fill: gray; -fx-font-size: 11px;" wrapText="true"/>
            <HBox spacing="6" alignment="CENTER_LEFT">
                <Label text="%rca.datalog.folder" minWidth="120"/>
                <TextField fx:id="datalogFolderField" HBox.hgrow="ALWAYS"
                           promptText="%rca.datalog.folder.prompt"/>
                <Button text="%button.browse" onAction="#onBrowseDatalogFolder"/>
            </HBox>
            <HBox spacing="6" alignment="CENTER_LEFT">
                <Label text="%rca.datalog.file" minWidth="120"/>
                <TextField fx:id="datalogFileField" HBox.hgrow="ALWAYS"
                           promptText="%rca.datalog.file.prompt"/>
                <Button text="%button.browse" onAction="#onBrowseDatalogFile"/>
            </HBox>
            <CheckBox fx:id="noDirectSiblings" text="%rca.no.direct.siblings"/>
        </VBox>
    </TitledPane>

    <!-- Options avancées -->
    <TitledPane fx:id="advancedPane" collapsible="true" expanded="false">
        <VBox spacing="6" style="-fx-padding: 8;">
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label text="%label.timeout"/>
                <Spinner fx:id="timeoutSpinner" prefWidth="75"/>
                <Label text="%label.timeout.hint"
                       style="-fx-text-fill: gray; -fx-font-size: 11px;"/>
            </HBox>
            <CheckBox fx:id="verboseCheckBox" text="%checkbox.verbose"/>
        </VBox>
    </TitledPane>

	<!-- Résultats -->
	<TitledPane fx:id="resultsPane" collapsible="true" expanded="false">
	    <VBox spacing="6" style="-fx-padding: 8;">
	        <Label fx:id="resultsFolderLabel"
	               style="-fx-text-fill: gray; -fx-font-size: 11px;" wrapText="true"/>
	        <ListView fx:id="dotFilesList" prefHeight="130"/>
	
	        <!-- Bouton RCAViz avec nom de fichier -->
	        <VBox spacing="3" alignment="CENTER_LEFT">
	            <Label fx:id="rcavizFileLabel"
	                   style="-fx-text-fill: gray; -fx-font-size: 10px; -fx-font-style: italic;"
	                   wrapText="true"/>
	            <Button onAction="#onOpenInRcaviz"
	                    text="▶  Open in RCAViz"
	                    style="-fx-background-color: #0047B3; -fx-text-fill: white;
	                           -fx-font-weight: bold; -fx-cursor: hand;
	                           -fx-padding: 6 16; -fx-background-radius: 4;"/>
	        </VBox>
	
	    </VBox>
	</TitledPane>
</VBox>
</ScrollPane>
