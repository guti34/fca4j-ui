<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToWidth="true"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="fr.lirmm.fca4j.ui.controller.RuleBasisController">
<VBox spacing="10" style="-fx-padding: 12;">

    <TitledPane fx:id="inputPane" collapsible="false">
        <VBox spacing="8" style="-fx-padding: 8;">
            <HBox spacing="6">
                <TextField fx:id="inputFileField" HBox.hgrow="ALWAYS"
                           promptText="%label.input.file"/>
                <Button text="%button.browse" onAction="#onBrowseInput"/>
                <Button fx:id="editInputButton" onAction="#onEditInput"/>
            </HBox>
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label text="%label.input.format"/>
                <ComboBox fx:id="inputFormatCombo" prefWidth="120"/>
            </HBox>
        </VBox>
    </TitledPane>

    <!-- Algorithme : section unique toujours visible -->
    <!--  - ligne algorithme + fermeture + clarification : RULEBASIS (masquées pour DBASIS) -->
    <!--  - implémentation : toujours visible -->
    <!--  - code natif : DBASIS (masqué pour RULEBASIS) -->
    <!--  - multithreading (mode + seuil) : en fin de section -->
    <TitledPane text="%section.algorithm" collapsible="false">
        <VBox spacing="8" style="-fx-padding: 8;">
            <HBox fx:id="algoRow" spacing="8" alignment="CENTER_LEFT">
                <Label text="%label.algorithm" minWidth="110"/>
                <ComboBox fx:id="algoCombo" prefWidth="160"/>
            </HBox>
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label fx:id="closureLabel" text="%label.closure" minWidth="110"/>
                <ComboBox fx:id="closureCombo" prefWidth="140"/>
            </HBox>
            <CheckBox fx:id="clarifyCheckBox" text="%checkbox.clarify"/>
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label text="%label.implementation" minWidth="110"/>
                <ComboBox fx:id="implCombo" prefWidth="160"/>
            </HBox>
            <CheckBox fx:id="enableNativeCodeCheckBox" text="%checkbox.enable.native.code"/>
            <Separator/>
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label text="%label.pool.mode" minWidth="110"/>
                <ComboBox fx:id="poolModeCombo" prefWidth="150"/>
            </HBox>
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label fx:id="thresholdLabel" text="%label.threshold" minWidth="110"/>
                <Spinner fx:id="thresholdSpinner" prefWidth="80"/>
            </HBox>
        </VBox>
    </TitledPane>

    <!-- Options D-Basis (support minimal) : DBASIS seulement -->
    <TitledPane fx:id="dbasisPane" collapsible="false">
        <VBox spacing="8" style="-fx-padding: 8;">
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label text="%label.min.support"/>
                <Spinner fx:id="minSupportSpinner" prefWidth="90"/>
                <Label text="%label.min.support.hint"
                       style="-fx-text-fill: gray; -fx-font-size: 11px;"/>
            </HBox>
        </VBox>
    </TitledPane>

    <TitledPane fx:id="outputPane" collapsible="false">
        <VBox spacing="8" style="-fx-padding: 8;">
            <HBox spacing="6">
                <TextField fx:id="outputFileField" HBox.hgrow="ALWAYS"
                           promptText="%label.output.file"/>
                <Button text="%button.browse" onAction="#onBrowseOutput"/>
            </HBox>
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label text="%label.output.format"/>
                <ComboBox fx:id="outputFormatCombo" prefWidth="110"/>
            </HBox>
        </VBox>
    </TitledPane>

    <TitledPane fx:id="advancedPane" collapsible="true" expanded="false">
        <VBox spacing="8" style="-fx-padding: 8;">
            <CheckBox fx:id="sortBySupportCheckBox" text="%checkbox.sort.support"/>
            <Label text="%label.report.file"/>
            <HBox spacing="6">
                <TextField fx:id="reportFileField" HBox.hgrow="ALWAYS"/>
                <Button text="%button.browse" onAction="#onBrowseReport"/>
            </HBox>
            <Label text="%label.impl.folder"/>
            <HBox spacing="6">
                <TextField fx:id="implFolderField" HBox.hgrow="ALWAYS"/>
                <Button text="%button.browse" onAction="#onBrowseImplFolder"/>
            </HBox>
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label text="%label.timeout"/>
                <Spinner fx:id="timeoutSpinner" prefWidth="80"/>
                <Label text="%label.timeout.hint"
                       style="-fx-text-fill: gray; -fx-font-size: 11px;"/>
            </HBox>
            <CheckBox fx:id="verboseCheckBox" text="%checkbox.verbose"/>
        </VBox>
    </TitledPane>

</VBox>
</ScrollPane>
