<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.web.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="fr.lirmm.fca4j.ui.controller.MainController"
            prefWidth="1200" prefHeight="750">
    <top>
        <VBox>
			<MenuBar>
			    <Menu text="%menu.file">
			
			        <!-- New -->
			        <Menu text="%menu.file.new">
			            <MenuItem text="%menu.file.new.context" onAction="#onNewContext"/>
			            <MenuItem text="%menu.file.new.family"  onAction="#onNewFamily"/>
    					<MenuItem text="%menu.file.new.model"   onAction="#onNewModel"/>
			        </Menu>
			
			        <!-- Open -->
			        <Menu text="%menu.file.open">
			            <MenuItem text="%menu.file.open.context" onAction="#onOpenContext"/>
			            <MenuItem text="%menu.file.open.family"  onAction="#onOpenFamily"/>
    					<MenuItem text="%menu.file.open.model"   onAction="#onOpenModel"/>
			        </Menu>
			
			        <!-- Recent -->
			        <Menu fx:id="recentContextMenu" text="%menu.file.recent.context"/>
			        <Menu fx:id="recentFamilyMenu"  text="%menu.file.recent.family"/>
			        <Menu fx:id="recentModelMenu"   text="%menu.file.recent.model"/>
			
			        <SeparatorMenuItem/>
			        <MenuItem text="%menu.file.preferences" onAction="#onOpenPreferences"/>
			        <SeparatorMenuItem/>
			        <MenuItem text="%menu.file.quit" onAction="#onQuit"/>
			    </Menu>
					<Menu text="%menu.help">
					    <MenuItem text="%menu.help.command"   onAction="#onCommandHelp"/>
					    <MenuItem text="%menu.help.website"   onAction="#onOpenWebsite"/>   <!-- AJOUT -->
					    <SeparatorMenuItem/>
					    <MenuItem text="%menu.help.shortcuts" onAction="#onShowShortcuts"/>
					    <SeparatorMenuItem/>
					    <MenuItem text="%menu.help.about" onAction="#onAbout"/>
					</Menu>			
			</MenuBar>
        </VBox>
    </top>

    <center>
    <StackPane fx:id="centerStack">
        <SplitPane dividerPositions="0.28">

            <!-- Panneau gauche : TabPane Context / RCA Family -->
            <TabPane fx:id="commandTabPane" tabClosingPolicy="UNAVAILABLE"
                     minWidth="280" prefWidth="310">

                <!-- Onglet Context : sélecteur + panneau paramètres -->
                <Tab fx:id="contextTab">
				    <BorderPane>
				        <!-- Sélecteur de commande en haut -->
				        <top>
				            <HBox spacing="8" alignment="CENTER_LEFT"
				                  style="-fx-padding: 6 8; -fx-border-color: #ddd;
				                         -fx-border-width: 0 0 1 0; -fx-background-color: #f5f5f5;">
				                <Label text="%toolbar.command"
				                       style="-fx-font-weight: bold;"/>
				                <ComboBox fx:id="commandCombo" prefWidth="160"
				                          HBox.hgrow="ALWAYS"/>
				            </HBox>
				        </top>
				        <!-- Panneau paramètres scrollable au centre -->
				        <center>
				            <StackPane fx:id="commandPanelContainer"/>
				        </center>
				        <!-- Bouton Run ancré en bas -->
				        <bottom>
				            <Button fx:id="contextRunButton"
				                    maxWidth="Infinity"
				                    style="-fx-font-weight: bold; -fx-font-size: 13px;
				                           -fx-background-color: #0047B3; -fx-text-fill: white;
				                           -fx-padding: 10; -fx-cursor: hand;"
				                    onAction="#onContextRun"/>
				        </bottom>
				    </BorderPane>
                </Tab>

                <!-- Onglet RCA Family : commande RCA -->
                <Tab fx:id="rcaTab">
				    <BorderPane>
				        <center>
				            <StackPane fx:id="rcaCommandContainer"/>
				        </center>
				        <bottom>
				            <Button fx:id="rcaRunButton"
				                    maxWidth="Infinity"
				                    style="-fx-font-weight: bold; -fx-font-size: 13px;
				                           -fx-background-color: #0047B3; -fx-text-fill: white;
				                           -fx-padding: 10; -fx-cursor: hand;"
				                    onAction="#onRcaRun"/>
				        </bottom>
				    </BorderPane>
                </Tab>
				<Tab fx:id="importTab">
				    <BorderPane>
				        <center>
				            <StackPane fx:id="importCommandContainer"/>
				        </center>
				        <bottom>
				            <Button fx:id="importRunButton"
				                    maxWidth="Infinity"
				                    style="-fx-font-weight: bold; -fx-font-size: 13px;
				                           -fx-background-color: #0047B3; -fx-text-fill: white;
				                           -fx-padding: 10; -fx-cursor: hand;"
				                    onAction="#onImportRun"/>
				        </bottom>
				    </BorderPane>
				</Tab>

            </TabPane>

            <!-- Panneau droit : onglets + console unique en bas -->
            <VBox>
            <SplitPane orientation="VERTICAL" dividerPositions="0.75" VBox.vgrow="ALWAYS">
            <TabPane fx:id="mainTabPane" tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">

                <!-- Onglet Graphe -->
			<Tab fx:id="conceptStructureTab" styleClass="concept-tab">
			    <VBox>
			        <!-- Toolbar export -->
						<ToolBar styleClass="editor-toolbar">
							<Button fx:id="btnOpenDot"   styleClass="icon-btn" onAction="#onOpenDot"/>
						    <Button fx:id="btnSaveDot"   styleClass="icon-btn" onAction="#onSaveDot"   disable="true"/>
						    <Separator/>
						    <Button fx:id="btnExportSvg" styleClass="icon-btn" onAction="#onExportSvg" disable="true"/>
						    <Button fx:id="btnExportPng" styleClass="icon-btn" onAction="#onExportPng" disable="true"/>
						    <Button fx:id="btnExportPdf" styleClass="icon-btn" onAction="#onExportPdf" disable="true"/>
							<Button fx:id="btnMagnifier" styleClass="icon-btn" onAction="#onToggleMagnifier" disable="true"/>
						    <Separator orientation="VERTICAL"/>
						    <Label fx:id="dotFileLabel"
						           style="-fx-font-weight: bold; -fx-text-fill: #0047B3; -fx-font-size: 12px;"/>
						</ToolBar>			        
						<WebView fx:id="graphWebView" VBox.vgrow="ALWAYS"/>
			    </VBox>
			</Tab>
			<!-- Onglet Viewer rules-->
		 	<Tab fx:id="rulesViewerTab" styleClass="rules-tab">
     			<fx:include fx:id="rulesViewer" source="rules_viewer.fxml"/>
 			</Tab>

                <!-- Onglet Éditeur de contexte -->
                <Tab fx:id="contextEditorTab" styleClass="editor-tab">
                    <fx:include fx:id="contextEditor"
                                source="context_editor.fxml"/>
                </Tab>

                <!-- Onglet Family Editor -->
                <Tab fx:id="familyEditorTab" styleClass="editor-tab">
                    <fx:include fx:id="familyEditor"
                                source="family_editor.fxml"/>
                </Tab>
				<!-- Onglet Model Editor -->
				<Tab fx:id="modelEditorTab" styleClass="editor-tab">
				    <fx:include fx:id="modelEditor"
				                source="model_editor.fxml"/>
				</Tab>
            </TabPane>
            <!-- Console unique partagée par tous les onglets -->
            <VBox>
                <HBox style="-fx-padding: 2 6; -fx-background-color: #2d2d2d;"
                      alignment="CENTER_LEFT">
                    <Label text="Console"
                           style="-fx-text-fill: #aaa; -fx-font-size: 11px;"/>
                    <Pane HBox.hgrow="ALWAYS"/>
                    <Button text="%toolbar.clear" onAction="#onClearConsole"
                            style="-fx-font-size: 10px;"/>
                </HBox>
                <TextArea fx:id="consoleArea" VBox.vgrow="ALWAYS"
                          editable="false"
                          style="-fx-font-family: monospace; -fx-font-size: 11px;"/>
            </VBox>
            </SplitPane>
            </VBox>
        </SplitPane>
    </StackPane>
</center>    

	<bottom>
	    <HBox style="-fx-padding: 3 8; -fx-border-color: #ccc;
	                 -fx-border-width: 1 0 0 0; -fx-background-color: #f5f5f5;"
	          spacing="16" alignment="CENTER_LEFT">
	        <Label text="FCA4J:" style="-fx-font-weight: bold; -fx-font-size: 11px;"/>
	        <Label fx:id="statusFca4jLabel" style="-fx-font-size: 11px;"/>
	        <Separator orientation="VERTICAL"/>
	        <Label text="GraphViz:" style="-fx-font-weight: bold; -fx-font-size: 11px;"/>
	        <Label fx:id="statusGraphvizLabel" style="-fx-font-size: 11px;"/>
	        <Pane HBox.hgrow="ALWAYS"/>
			<Label fx:id="lastCommandLabel" style="-fx-font-size: 11px; -fx-font-weight: bold;"/>
			<Separator orientation="VERTICAL"/>
			<Button fx:id="btnHelp" styleClass="icon-btn" onAction="#onCommandHelp"
			        style="-fx-background-color: transparent; -fx-cursor: hand;"/>
			<Separator orientation="VERTICAL"/>
	        <Label fx:id="selectedNodeLabel" style="-fx-font-size: 11px;"/>
	    </HBox>
	</bottom>
</BorderPane>
