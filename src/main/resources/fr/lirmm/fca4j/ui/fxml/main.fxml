<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.web.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="fr.lirmm.fca4j.ui.controller.MainController"
            prefWidth="1200" prefHeight="750">
    <top>
        <VBox>
            <MenuBar>
                <Menu text="%menu.file">
                    <MenuItem text="%menu.file.preferences" onAction="#onOpenPreferences"/>
                    <SeparatorMenuItem/>
                    <MenuItem text="%menu.file.quit" onAction="#onQuit"/>
                </Menu>
                <Menu text="%menu.help">
                    <MenuItem text="%menu.help.about" onAction="#onAbout"/>
                </Menu>
            </MenuBar>
            <ToolBar>
                <Label fx:id="statusLabel"/>
            </ToolBar>
        </VBox>
    </top>

    <center>
        <SplitPane dividerPositions="0.28">

            <!-- Panneau gauche : TabPane Context / RCA Family -->
            <TabPane fx:id="commandTabPane" tabClosingPolicy="UNAVAILABLE"
                     minWidth="280" prefWidth="310">

                <!-- Onglet Context : sélecteur + panneau paramètres -->
                <Tab fx:id="contextTab">
                    <VBox spacing="0">
                        <!-- Sélecteur de commande intégré à l'onglet -->
                        <HBox spacing="8" alignment="CENTER_LEFT"
                              style="-fx-padding: 6 8; -fx-border-color: #ddd;
                                     -fx-border-width: 0 0 1 0; -fx-background-color: #f5f5f5;">
                            <Label text="%toolbar.command"
                                   style="-fx-font-weight: bold;"/>
                            <ComboBox fx:id="commandCombo" prefWidth="160"
                                      HBox.hgrow="ALWAYS"/>
                        </HBox>
                        <!-- Panneau paramètres de la commande sélectionnée -->
                        <StackPane fx:id="commandPanelContainer" VBox.vgrow="ALWAYS"/>
                    </VBox>
                </Tab>

                <!-- Onglet RCA Family : commande RCA -->
                <Tab fx:id="rcaTab">
                    <StackPane fx:id="rcaCommandContainer"/>
                </Tab>

            </TabPane>

            <!-- Panneau droit : onglets Graph / Context Editor / Family Editor -->
            <TabPane fx:id="mainTabPane" tabClosingPolicy="UNAVAILABLE">

                <!-- Onglet Graphe -->
                <Tab text="%tab.graph">
                    <SplitPane orientation="VERTICAL" dividerPositions="0.70">
                        <WebView fx:id="graphWebView"/>
                        <VBox>
                            <HBox style="-fx-padding: 2 6; -fx-background-color: #2d2d2d;"
                                  alignment="CENTER_LEFT">
                                <Label text="Console"
                                       style="-fx-text-fill: #aaa; -fx-font-size: 11px;"/>
                                <Pane HBox.hgrow="ALWAYS"/>
                                <Button text="%toolbar.clear" onAction="#onClearConsole"
                                        style="-fx-font-size: 10px;"/>
                            </HBox>
                            <TextArea fx:id="consoleArea" VBox.vgrow="ALWAYS"
                                      editable="false"
                                      style="-fx-font-family: monospace; -fx-font-size: 11px;"/>
                        </VBox>
                    </SplitPane>
                </Tab>

                <!-- Onglet Éditeur de contexte -->
                <Tab text="%tab.editor">
                    <fx:include fx:id="contextEditor"
                                source="context_editor.fxml"/>
                </Tab>

                <!-- Onglet Family Editor -->
                <Tab fx:id="familyEditorTab">
                    <fx:include fx:id="familyEditor"
                                source="family_editor.fxml"/>
                </Tab>

            </TabPane>
        </SplitPane>
    </center>

    <bottom>
        <HBox style="-fx-padding: 4 8; -fx-border-color: #ccc; -fx-border-width: 1 0 0 0;"
              spacing="12" alignment="CENTER_LEFT">
            <Label text="%panel.node.label" style="-fx-font-weight: bold;"/>
            <Label fx:id="selectedNodeLabel"/>
        </HBox>
    </bottom>
</BorderPane>
