<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToWidth="true"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="fr.lirmm.fca4j.ui.controller.InspectController">
<VBox spacing="10" style="-fx-padding: 12;">

    <!-- Entrée -->
    <TitledPane fx:id="inputPane" collapsible="false">
        <VBox spacing="8" style="-fx-padding: 8;">
            <HBox spacing="6">
                <TextField fx:id="inputFileField" HBox.hgrow="ALWAYS"
                           promptText="%label.input.file"/>
                <Button text="%button.browse" onAction="#onBrowseInput"/>
                <Button fx:id="editInputButton" onAction="#onEditInput"/>
            </HBox>
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label text="%label.input.format"/>
                <ComboBox fx:id="inputFormatCombo" prefWidth="120"/>
            </HBox>
        </VBox>
    </TitledPane>

    <!-- Options avancées -->
    <TitledPane fx:id="advancedPane" collapsible="true" expanded="false">
        <VBox spacing="8" style="-fx-padding: 8;">
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label text="%label.timeout"/>
                <Spinner fx:id="timeoutSpinner" prefWidth="80"/>
                <Label text="%label.timeout.hint"
                       style="-fx-text-fill: gray; -fx-font-size: 11px;"/>
            </HBox>
            <CheckBox fx:id="verboseCheckBox" text="%checkbox.verbose"/>
        </VBox>
    </TitledPane>


</VBox>
</ScrollPane>
