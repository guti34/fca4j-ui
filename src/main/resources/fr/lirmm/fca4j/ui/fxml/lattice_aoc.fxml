<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToWidth="true"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="fr.lirmm.fca4j.ui.controller.LatticeAocController">
<VBox spacing="10" style="-fx-padding: 12;">

    <TitledPane fx:id="inputPane" collapsible="false">
        <VBox spacing="8" style="-fx-padding: 8;">
            <HBox spacing="6">
                <TextField fx:id="inputFileField" HBox.hgrow="ALWAYS"
                           promptText="%label.input.file"/>
                <Button text="%button.browse" onAction="#onBrowseInput"/>
            </HBox>
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label text="%label.input.format"/>
                <ComboBox fx:id="inputFormatCombo" prefWidth="120"/>
                <Label fx:id="separatorLabel" text="%label.separator"/>
                <ComboBox fx:id="separatorCombo" prefWidth="110"/>
            </HBox>
        </VBox>
    </TitledPane>

    <TitledPane fx:id="outputPane" collapsible="false">
        <VBox spacing="8" style="-fx-padding: 8;">
            <HBox spacing="6">
                <TextField fx:id="outputFileField" HBox.hgrow="ALWAYS"
                           promptText="%label.output.file"/>
                <Button text="%button.browse" onAction="#onBrowseOutput"/>
            </HBox>
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label text="%label.output.format"/>
                <ComboBox fx:id="outputFormatCombo" prefWidth="100"/>
            </HBox>
        </VBox>
    </TitledPane>

    <TitledPane fx:id="algoPane" collapsible="false">
        <VBox spacing="8" style="-fx-padding: 8;">
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label text="%label.algorithm"/>
                <ComboBox fx:id="algoCombo" prefWidth="160"/>
            </HBox>
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label fx:id="icebergLabel" text="%label.iceberg.percent"/>
                <Spinner fx:id="icebergSpinner" prefWidth="80"/>
            </HBox>
        </VBox>
    </TitledPane>

    <TitledPane fx:id="graphvizPane" collapsible="true" expanded="true">
        <VBox spacing="8" style="-fx-padding: 8;">
            <CheckBox fx:id="dotCheckBox" text="%checkbox.generate.dot"/>
            <HBox spacing="6">
                <TextField fx:id="dotFileField" HBox.hgrow="ALWAYS"
                           promptText="%label.dot.file"/>
                <Button fx:id="dotBrowseButton" text="%button.browse" onAction="#onBrowseDot"/>
            </HBox>
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label text="%label.display.mode"/>
                <ComboBox fx:id="displayModeCombo" prefWidth="130"/>
            </HBox>
            <CheckBox fx:id="stabilityCheckBox" text="%checkbox.stability"/>
        </VBox>
    </TitledPane>

    <TitledPane fx:id="advancedPane" collapsible="true" expanded="false">
        <VBox spacing="8" style="-fx-padding: 8;">
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label text="%label.implementation"/>
                <ComboBox fx:id="implCombo" prefWidth="160"/>
            </HBox>
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label text="%label.timeout"/>
                <Spinner fx:id="timeoutSpinner" prefWidth="80"/>
                <Label text="%label.timeout.hint"
                       style="-fx-text-fill: gray; -fx-font-size: 11px;"/>
            </HBox>
            <CheckBox fx:id="verboseCheckBox" text="%checkbox.verbose"/>
        </VBox>
    </TitledPane>

    <Button fx:id="runButton" maxWidth="Infinity"
            onAction="#onRun"
            style="-fx-font-weight: bold; -fx-font-size: 13px;"/>

</VBox>
</ScrollPane>
