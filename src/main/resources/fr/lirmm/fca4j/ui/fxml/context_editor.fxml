<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="fr.lirmm.fca4j.ui.controller.ContextEditorController"
      spacing="0">

    <!-- ── Toolbar ── -->
    <ToolBar>
        <!-- Fichier -->
        <Button text="%editor.btn.new"    onAction="#onNewContext"/>
        <Button text="%editor.btn.open"   onAction="#onOpen"/>
        <Button text="%editor.btn.save"   onAction="#onSave"/>
        <Button text="%editor.btn.saveas" onAction="#onSaveAs"/>
        <Separator orientation="VERTICAL"/>
        <!-- Structure -->
        <Button text="%editor.btn.add.object"    onAction="#onAddObject"/>
        <Button text="%editor.btn.add.attr"      onAction="#onAddAttribute"/>
        <Button text="%editor.btn.del.object"    onAction="#onRemoveObject"/>
        <Button text="%editor.btn.del.attr"      onAction="#onRemoveAttribute"/>
        <Separator orientation="VERTICAL"/>
        <!-- Renommer le contexte -->
        <Button text="%editor.btn.rename" onAction="#onRenameContext"/>
        <Pane HBox.hgrow="ALWAYS"/>
        <!-- Infos -->
        <Label fx:id="statsLabel" style="-fx-text-fill: gray; -fx-font-size: 11px;"/>
    </ToolBar>

    <!-- ── Titre du contexte ── -->
    <HBox style="-fx-padding: 4 8; -fx-background-color: #f0f0f0;"
          alignment="CENTER_LEFT" spacing="8">
        <Label text="%editor.context.label" style="-fx-font-weight: bold;"/>
        <Label fx:id="contextNameLabel"/>
    </HBox>

    <!-- ── Tableau principal ── -->
    <TableView fx:id="tableView" VBox.vgrow="ALWAYS"
               style="-fx-font-size: 12px;">
    </TableView>

    <!-- ── Barre de statut ── -->
    <Label fx:id="statusLabel"
           style="-fx-padding: 2 8; -fx-font-size: 11px;
                  -fx-border-color: #ccc; -fx-border-width: 1 0 0 0;"/>

</VBox>
