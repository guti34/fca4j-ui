<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="fr.lirmm.fca4j.ui.controller.ContextEditorController"
      spacing="0">

    <!-- ── Toolbar ── -->
    <ToolBar styleClass="editor-toolbar">

        <Button fx:id="btnNew"    styleClass="icon-btn" onAction="#onNewContext"/>
        <Button fx:id="btnOpen"   styleClass="icon-btn" onAction="#onOpen"/>
        <Button fx:id="btnSave"   styleClass="icon-btn" onAction="#onSave"/>
        <Button fx:id="btnSaveAs" styleClass="icon-btn" onAction="#onSaveAs"/>

        <Separator orientation="VERTICAL"/>

        <Button fx:id="btnAddObject" styleClass="icon-btn" onAction="#onAddObject"/>
        <Button fx:id="btnDelObject" styleClass="icon-btn" onAction="#onRemoveObject"/>
        <Button fx:id="btnAddAttr"   styleClass="icon-btn" onAction="#onAddAttribute"/>
        <Button fx:id="btnDelAttr"   styleClass="icon-btn" onAction="#onRemoveAttribute"/>
        <Button fx:id="btnRename"    styleClass="icon-btn" onAction="#onRename"/>

        <Separator orientation="VERTICAL"/>

        <HBox spacing="4" alignment="CENTER_LEFT">
            <Label fx:id="fileNameLabel"
                   style="-fx-font-weight: bold; -fx-text-fill: #0047B3; -fx-font-size: 12px;"/>
            <Label fx:id="separatorLabel" text=" — "
                   style="-fx-text-fill: #0047B3;" visible="false" managed="false"/>
            <Label fx:id="contextNameLabel"
                   style="-fx-font-weight: bold; -fx-text-fill: #0047B3; -fx-cursor: hand;"/>
        </HBox>
        <Label fx:id="statsLabel"
               style="-fx-text-fill: gray; -fx-font-size: 11px; -fx-padding: 0 0 0 12;"/>
        <Pane HBox.hgrow="ALWAYS"/>

    </ToolBar>

    <!-- ── Corps : double Canvas + scrollbars ── -->
    <HBox VBox.vgrow="ALWAYS" spacing="0">

        <!--
            Canvas gauche — noms des objets.
            Même HEADER_H que le canvas principal => alignement pixel-perfect.
            Largeur fixe, hauteur suit le panneau.
        -->
        <Pane fx:id="objCanvasPane"
              minWidth="155" maxWidth="155" prefWidth="155"
              style="-fx-background-color: white;"/>

        <!--
            Canvas principal + scrollbars manuelles.
            BorderPane pour positionner les barres à droite et en bas.
        -->
        <BorderPane HBox.hgrow="ALWAYS">
            <center>
                <Pane fx:id="mainCanvasPane"
                      style="-fx-background-color: white;"/>
            </center>
            <right>
                <ScrollBar fx:id="vScrollBar"
                           orientation="VERTICAL"
                           unitIncrement="24"
                           blockIncrement="120"/>
            </right>
            <bottom>
                <ScrollBar fx:id="hScrollBar"
                           orientation="HORIZONTAL"
                           unitIncrement="28"
                           blockIncrement="140"/>
            </bottom>
        </BorderPane>

    </HBox>

    <!-- ── Barre de statut ── -->
    <Label fx:id="statusLabel" styleClass="status-bar"/>

</VBox>
