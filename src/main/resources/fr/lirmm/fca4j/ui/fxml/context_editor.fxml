<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="fr.lirmm.fca4j.ui.controller.ContextEditorController"
      spacing="0">

    <!-- ── Toolbar ── -->
    <ToolBar styleClass="editor-toolbar">

        <!-- Groupe Fichier -->
        <Button fx:id="btnNew"    styleClass="icon-btn" onAction="#onNewContext"/>
        <Button fx:id="btnOpen"   styleClass="icon-btn" onAction="#onOpen"/>
        <Button fx:id="btnSave"   styleClass="icon-btn" onAction="#onSave"/>
        <Button fx:id="btnSaveAs" styleClass="icon-btn" onAction="#onSaveAs"/>

        <Separator orientation="VERTICAL"/>

        <!-- Groupe Structure -->
        <Button fx:id="btnAddObject"    styleClass="icon-btn" onAction="#onAddObject"/>
        <Button fx:id="btnAddAttr"      styleClass="icon-btn" onAction="#onAddAttribute"/>
        <Button fx:id="btnDelObject"    styleClass="icon-btn" onAction="#onRemoveObject"/>
        <Button fx:id="btnDelAttr"      styleClass="icon-btn" onAction="#onRemoveAttribute"/>

        <Separator orientation="VERTICAL"/>

        <!-- Renommer le contexte -->
        <Button fx:id="btnRename" styleClass="icon-btn" onAction="#onRenameContext"/>

        <Pane HBox.hgrow="ALWAYS"/>

        <!-- Statistiques -->
        <Label fx:id="statsLabel" styleClass="stats-label"/>
    </ToolBar>

    <!-- ── Titre du contexte ── -->
    <HBox styleClass="context-header" alignment="CENTER_LEFT" spacing="8">
        <Label text="%editor.context.label" styleClass="context-header-label"/>
        <Label fx:id="contextNameLabel" styleClass="context-name-label"/>
    </HBox>

    <!-- ── Tableau principal ── -->
    <TableView fx:id="tableView" VBox.vgrow="ALWAYS"/>

    <!-- ── Barre de statut ── -->
    <Label fx:id="statusLabel" styleClass="status-bar"/>

</VBox>
